# Realtime voice/video (OpenAI Realtime + ElevenLabs streaming TTS)
OPENAI_API_KEY=
# Hesabınızda listelenen model: GET /v1/models (realtime içeren id'ler)
# Eski gpt-4o-mini-realtime-preview birçok key'de artık yok → gpt-realtime-mini
OPENAI_REALTIME_MODEL=gpt-realtime-mini
# OPENAI_RT_VERBOSE=1
ELEVENLABS_API_KEY=
REALTIME_WS_PATH=/realtime
VOICE_CHAT_VERSION=v2
