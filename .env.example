PORT=3011

# debug | info | warn | error
LOG_LEVEL=info
# Yavaş istek uyarısı eşiği (ms)
SLOW_REQUEST_MS=5000

DB_HOST=5.39.8.160
DB_PORT=3306
DB_USER=flywork1_lingolabuddyUser
DB_PASSWORD=
DB_NAME=flywork1_lingolabuddy
DB_SSL=false

JWT_SECRET=
JWT_EXPIRES_IN=30d
JWT_ISSUER=lingola-api
JWT_AUDIENCE=lingola-buddy-app

# Firebase Admin — service account JSON (tek satır) veya dosya yolu
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

BUNNY_CDN_STORAGE_ZONE=lingolabuddy
BUNNY_CDN_STORAGE_PASSWORD=
